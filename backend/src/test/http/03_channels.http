### ─────────────────────────────────────────────────────────────────────────
### CHANNEL ENDPOINTS
### Requires: {{authToken}}, {{authToken2}}, {{serverId}} from 01_auth + 02_servers
### ─────────────────────────────────────────────────────────────────────────

### [1] Create a new text channel "backend"
POST {{baseUrl}}/servers/{{serverId}}/channels
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "backend",
  "type": "TEXT"
}

> {%
  client.test("Status 201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  client.test("Channel name matches", function() {
    client.assert(response.body.name === "backend", "name mismatch");
  });
  client.test("Channel type is TEXT", function() {
    client.assert(response.body.type === "TEXT", "type mismatch");
  });
  client.test("Belongs to correct server", function() {
    client.assert(response.body.serverId === client.global.get("serverId"), "serverId mismatch");
  });
  client.global.set("channelId2", response.body.id);
%}


### [2] Create a second channel "frontend"
POST {{baseUrl}}/servers/{{serverId}}/channels
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "frontend",
  "type": "TEXT"
}

> {%
  client.test("Status 201 Created", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  client.global.set("channelId3", response.body.id);
%}


### [3] List channels for the server
GET {{baseUrl}}/servers/{{serverId}}/channels
Authorization: Bearer {{authToken}}

> {%
  client.test("Status 200 OK", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  client.test("Returns array of channels", function() {
    client.assert(Array.isArray(response.body), "expected array");
  });
  client.test("At least 3 channels (general + backend + frontend)", function() {
    client.assert(response.body.length >= 3, "expected 3+ channels, got " + response.body.length);
  });
%}


### [4] Create channel as non-member → 403
POST {{baseUrl}}/servers/{{serverId}}/channels
Content-Type: application/json
Authorization: Bearer {{authToken2}}

{
  "name": "hacked",
  "type": "TEXT"
}

> {%
  client.test("Status 403 Forbidden", function() {
    client.assert(response.status === 403, "Expected 403, got " + response.status);
  });
%}


### [5] Create channel with invalid name (empty) → 400
POST {{baseUrl}}/servers/{{serverId}}/channels
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "",
  "type": "TEXT"
}

> {%
  client.test("Status 400 Bad Request", function() {
    client.assert(response.status === 400, "Expected 400, got " + response.status);
  });
%}


### [6] Bob joins the server first (re-join for channel tests)
POST {{baseUrl}}/servers/join/{{inviteCode}}
Authorization: Bearer {{authToken2}}

> {%
  // Bob may already be a member from 02_servers tests — ignore 409
  client.test("Status 200 or 409", function() {
    client.assert(
      response.status === 200 || response.status === 409,
      "Expected 200 or 409, got " + response.status
    );
  });
%}


### [7] Bob creates a channel as MEMBER → 403
POST {{baseUrl}}/servers/{{serverId}}/channels
Content-Type: application/json
Authorization: Bearer {{authToken2}}

{
  "name": "bob-attempt",
  "type": "TEXT"
}

> {%
  client.test("Status 403 Forbidden", function() {
    client.assert(response.status === 403, "Expected 403, got " + response.status);
  });
%}


### [8] Delete a channel (owner only)
DELETE {{baseUrl}}/servers/{{serverId}}/channels/{{channelId3}}
Authorization: Bearer {{authToken}}

> {%
  client.test("Status 204 No Content", function() {
    client.assert(response.status === 204, "Expected 204, got " + response.status);
  });
%}


### [9] Get channel after deletion → 404
GET {{baseUrl}}/servers/{{serverId}}/channels/{{channelId3}}
Authorization: Bearer {{authToken}}

> {%
  client.test("Status 404 Not Found", function() {
    client.assert(response.status === 404, "Expected 404, got " + response.status);
  });
%}


### [10] Delete channel as non-owner → 403
DELETE {{baseUrl}}/servers/{{serverId}}/channels/{{channelId2}}
Authorization: Bearer {{authToken2}}

> {%
  client.test("Status 403 Forbidden", function() {
    client.assert(response.status === 403, "Expected 403, got " + response.status);
  });
%}
