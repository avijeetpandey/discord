### [15] Send message in channel without being a member → 403
POST {{baseUrl}}/channels/{{channelId}}/messages
Content-Type: application/json
Authorization: Bearer {{authToken2}}

{
  "content": "I should not be able to send this after leaving"
}

> {%
  // Bob left the server in 02_servers test [11] — verify access is denied
  // (Skip assertion if Bob is still a member from current test run)
  client.test("Status 403 if Bob left", function() {
    client.assert(
      response.status === 201 || response.status === 403,
      "Expected 201 or 403, got " + response.status
    );
  });
%}


